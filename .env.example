# Application
APP_NAME=CryptoPaymentGateway
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=false
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ADMIN_SECRET_KEY=change-me-generate-a-long-random-admin-secret
HOSTED_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database / Redis
DATABASE_URL=postgresql+asyncpg://gateway:payment_gateway_password@localhost:5433/payment_gateway
REDIS_URL=redis://localhost:6380/0

# Crypto material
# Generate: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
ENCRYPTION_KEY=replace-with-base64-32-byte-key
# Generate: python -c "from mnemonic import Mnemonic; print(Mnemonic('english').generate(256))"
HD_WALLET_SEED=
HD_MASTER_SEED=
SOLANA_WALLET_SEED=
TON_WALLET_SEED=

# Treasury / funding
TREASURY_ADDRESS=
BASE_TREASURY_ADDRESS=
ARB_TREASURY_ADDRESS=
BSC_TREASURY_ADDRESS=
SOLANA_TREASURY_ADDRESS=
TON_TREASURY_ADDRESS=
FUNDER_PRIVATE_KEY=

# Non-EVM RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
TON_RPC_URL=https://toncenter.com/api/v2
TON_API_KEY=

# Workers
POLL_INTERVAL_SECONDS=5
SCAN_WINDOW_SIZE=2000
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_TIMEOUT_SECONDS=30

# Security limits
MIN_DEPOSIT_USDT=0.01
MIN_DEPOSIT_USDC=0.01
MAX_DEPOSIT_USDT=1000000
MAX_DEPOSIT_USDC=1000000
