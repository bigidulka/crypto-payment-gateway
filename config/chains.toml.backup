address_length = 42

[chains.arbitrum.tokens.USDT]
symbol = "USDT"
contract_address = "0xFd086bC7CD5C481DCC9C85ebE478A1C0b69FCbb9"
decimals = 6
variant = "native"

[chains.arbitrum.tokens.USDC]
symbol = "USDC"
contract_address = "0xaf88d065e77c8cC2239327C5EDb3A432268e5831"
decimals = 6
variant = "native"


[chains.bsc]
name = "BNB Smart Chain"
chain_id = 56
chain_type = "evm"
is_l2 = false
max_gas_cost_native = 0.0005  # BNB - reduced fallback
