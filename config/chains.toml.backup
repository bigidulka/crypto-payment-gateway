# =============================================================================
# CHAINS CONFIGURATION
# =============================================================================
# Все настройки сетей, токенов, контрактов и RPC
# Чтобы добавить/удалить чейн - просто раскомментируйте/закомментируйте секцию
# =============================================================================

# Global constants
[constants]
# ERC20 Transfer event signature (стандартный для всех EVM)
transfer_event_signature = "0xddf252ad1be2c89b69c2b068fc378daa952ba7f163c4a11628f55a4df523b3ef"

# Multicall3 contract address (одинаковый на всех EVM сетях)
multicall3_address = "0xcA11bde05977b3631167028862bE2a173976CA11"

# Gas configuration
gas_buffer_percent = 10
max_gas_top_up_retries = 3

# =============================================================================
# EVM CHAINS
# =============================================================================

[chains.base]
name = "Base"
chain_id = 8453
chain_type = "evm"
is_l2 = true
max_gas_cost_native = 0.0005  # ETH - достаточно для L2 с L1 data fee
gas_multiplier = 1.25
min_funder_balance = 0.001  # Minimum balance to consider funder healthy
rpc_urls = [
    "https://gateway.tenderly.co/public/base",
    "https://base.lava.build",
    "https://base-public.nodies.app",
    "https://base-mainnet.public.blastapi.io",
]
confirmations = 12
reorg_buffer = 20
scan_window = 2000
block_time_sec = 2.0
native_symbol = "ETH"
native_decimals = 18
explorer_url = "https://basescan.org"
address_length = 42

[chains.base.tokens.USDT]
symbol = "USDT"
contract_address = "0xfde4C96c8593536E31F229EA8f37b2ADa2699bb2"
decimals = 6
variant = "bridged"

[chains.base.tokens.USDC]
symbol = "USDC"
contract_address = "0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913"
decimals = 6
variant = "native"


[chains.arbitrum]
name = "Arbitrum One"
chain_id = 42161
chain_type = "evm"
is_l2 = true
max_gas_cost_native = 0.0005  # ETH - L2 with L1 data fee
gas_multiplier = 1.25
min_funder_balance = 0.001
rpc_urls = [
    "https://arbitrum.gateway.tenderly.co",
    "https://arbitrum-one.public.blastapi.io",
    "https://arbitrum-one-public.nodies.app",
    "https://arbitrum.meowrpc.com",
]
confirmations = 12
reorg_buffer = 50
scan_window = 2000
block_time_sec = 0.25
native_symbol = "ETH"
native_decimals = 18
