reorg_buffer = 30
scan_window = 2000
block_time_sec = 3.0
native_symbol = "BNB"
native_decimals = 18
explorer_url = "https://bscscan.com"
address_length = 42

[chains.bsc.tokens.USDT]
symbol = "USDT"
contract_address = "0x55d398326f99059fF775485246999027B3197955"
decimals = 18  # BSC USDT has 18 decimals!
variant = "native"

[chains.bsc.tokens.USDC]
